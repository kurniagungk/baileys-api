{
	"compilerOptions": {
		"target": "ES2020",
		"module": "CommonJS",
		"useUnknownInCatchVariables": true,
		"declaration": true,
		"declarationMap": true,
		"lib": ["ES2020"],
		"outDir": "dist/",
		"baseUrl": ".",
		"rootDir": "src",
		"resolveJsonModule": true,
		"removeComments": true,
		"noEmitOnError": true,
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"strictNullChecks": true,
		"noImplicitAny": true,
		"skipLibCheck": true,
		"incremental": true,
		"paths": {
			"@/*": [
				"src/*"
			]
		}
	},
	"include": ["src"],
	"exclude": ["node_modules", "prisma", "dist"],
	"ts-node": {
		"require": ["tsconfig-paths/register"]
	}
}